FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=replace-this-before-deployment
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/webshield_lab
FRONTEND_ORIGINS=http://127.0.0.1:5000,http://localhost:5000,http://127.0.0.1:5500,http://localhost:5500
AUTO_CREATE_TABLES=true
LAB_MODE=secure
PERMANENT_SESSION_MINUTES=30
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=600
LOGIN_RATE_LIMIT_LOCKOUT_SECONDS=300
ERROR_LOG_PATH=backend/logs/error.log
ERROR_LOG_MAX_BYTES=1048576
ERROR_LOG_BACKUP_COUNT=3
